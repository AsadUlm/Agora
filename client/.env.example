# AGORA frontend configuration
# Copy this file to client/.env for local development.

# Optional: HTTP API base URL. Leave empty in the bundled production image
# to use same-origin requests.
VITE_API_BASE_URL=http://localhost:8000

# Optional: WebSocket origin. Leave empty in the bundled production image
# to derive ws:// or wss:// from the current browser origin.
VITE_WS_BASE_URL=ws://localhost:8000
