# AGORA backend configuration
# Copy this file to server/.env and replace required/conditional placeholders.

# Application
APP_ENV=development
CORS_ORIGINS=http://localhost:5173
# Optional: container/PaaS listen port. Local uvicorn commands set the port explicitly.
PORT=8080

# Database
# Required: PostgreSQL with the pgvector extension is the production target.
DATABASE_URL=postgresql+asyncpg://username:password@localhost:5432/agora

# Authentication
# Required: replace with a long, random value.
JWT_SECRET=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# Default startup seed user
# Required: created only when the configured email does not already exist.
DEFAULT_USER_EMAIL=admin@example.com
# Required: replace before first startup; never use this placeholder in production.
DEFAULT_USER_PASSWORD=replace_with_a_strong_password
DEFAULT_USER_NAME=Admin

# Debate and LLM execution
LLM_PROVIDER=openrouter
LLM_MODEL=anthropic/claude-sonnet-4.5
LLM_TEMPERATURE=0.7
LLM_MAX_CONCURRENT_AGENT_CALLS=3
MAX_DEBATE_AGENTS=4

# Dedicated final moderator
MODERATOR_PROVIDER=openrouter
MODERATOR_MODEL=anthropic/claude-sonnet-4-6
MODERATOR_TEMPERATURE=0.2
MODERATOR_MAX_TOKENS=2000

# Topic guard
TOPIC_GUARD_ENABLED=true
TOPIC_GUARD_MODEL=google/gemini-flash-1.5
TOPIC_GUARD_MAX_TOKENS=300
TOPIC_GUARD_TIMEOUT_S=4.0
TOPIC_GUARD_CACHE_TTL_S=3600
TOPIC_GUARD_MIN_CONFIDENCE=0.75

# AI / LLM provider credentials
# Conditionally required when OpenRouter is used for debate, moderator,
# topic-guard, knowledge extraction, or embeddings.
OPENROUTER_API_KEY=your_openrouter_api_key_here
# Optional: enables the Groq provider when set.
GROQ_API_KEY=
# Optional: required only when EMBEDDING_PROVIDER=openai.
OPENAI_API_KEY=
# Optional: required only when EMBEDDING_PROVIDER=gemini.
GEMINI_API_KEY=

# OpenRouter
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: attribution header sent to OpenRouter.
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=AGORA

# RAG / embeddings
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=google/gemini-embedding-2-preview
# Must match the pgvector column dimension in the current schema.
EMBEDDING_DIM=768
# Optional: overrides the embedding API base URL.
EMBEDDING_BASE_URL=
# Optional: permits zero-vector fallback outside tests; keep false for real RAG.
EMBEDDING_ALLOW_MOCK_FALLBACK=false

# Document processing
UPLOAD_DIR=uploads
DOCUMENT_MAX_FILE_SIZE_MB=20
DOCUMENT_MAX_FILES_PER_UPLOAD=10
DOCUMENT_PROCESSING_TIMEOUT_SECONDS=300
KNOWLEDGE_EXTRACTION_TIMEOUT_SECONDS=30.0

# Document storage
DOCUMENT_STORAGE_PROVIDER=local
# Conditionally required only when DOCUMENT_STORAGE_PROVIDER=cloudinary.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=agora/documents
CLOUDINARY_RESOURCE_TYPE=raw
